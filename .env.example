LOCAL_VISION_HOST=0.0.0.0
LOCAL_VISION_PORT=6000
LOCAL_VISION_RELOAD=false
LOCAL_VISION_LOG_LEVEL=info

# Default remains the current Qwen model. To use another Hugging Face
# vision-language model, change LOCAL_VISION_MODEL_ID and set
# LOCAL_VISION_MODEL_FAMILY=auto if it is not Qwen2.5-VL.
LOCAL_VISION_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VISION_MODEL_FAMILY=qwen2_5_vl
LOCAL_VISION_AUTO_MODEL_CLASS=auto_image_text_to_text

# Use transformers or vllm. vLLM must be installed separately with `pip install vllm`.
LOCAL_VISION_BACKEND=transformers
LOCAL_VISION_VLLM_MAX_MODEL_LEN=4096
LOCAL_VISION_VLLM_MAX_NUM_SEQS=8
LOCAL_VISION_VLLM_MAX_CONCURRENT_REQUESTS=8
LOCAL_VISION_VLLM_TENSOR_PARALLEL_SIZE=1
LOCAL_VISION_VLLM_GPU_MEMORY_UTILIZATION=0.85
LOCAL_VISION_VLLM_CPU_OFFLOAD_GB=0
LOCAL_VISION_VLLM_DTYPE=auto
LOCAL_VISION_VLLM_QUANTIZATION=
LOCAL_VISION_VLLM_ATTENTION_BACKEND=
LOCAL_VISION_VLLM_USE_FLASHINFER_SAMPLER=

LOCAL_VISION_DEVICE=cuda
LOCAL_VISION_LOAD_MODEL_ON_STARTUP=true
LOCAL_VISION_TRUST_REMOTE_CODE=false
LOCAL_VISION_USE_FLASH_ATTENTION=false

LOCAL_VISION_DEFAULT_MAX_NEW_TOKENS=100
LOCAL_VISION_MAX_NEW_TOKENS_LIMIT=256
LOCAL_VISION_MAX_IMAGE_PIXELS=16777216
LOCAL_VISION_MAX_IMAGE_BYTES=20971520
LOCAL_VISION_MIN_PIXELS=200704
LOCAL_VISION_MAX_PIXELS=1003520
